<h3>📦 Installation</h3>
<p>Requires <a href="https://php.net/releases/" target="_blank">PHP 8.4+</a> (uses property hooks). Install via <a href="https://getcomposer.org/" target="_blank">Composer</a>:</p>
<pre class="language-bash prettyprint">composer require oihana/php-standards</pre>

<h3>🗂 What's inside</h3>
<table>
    <thead>
        <tr><th>Namespace</th><th>Coverage</th></tr>
    </thead>
    <tbody>
        <tr><td><code>org\iso</code></td><td>ISO 8601 (date/time/duration/interval/recurrence + format), ISO 3166-1, ISO 639-1, ISO 4217, ISO 15924</td></tr>
        <tr><td><code>org\ietf</code></td><td>BCP 47 / RFC 5646 locale tags</td></tr>
        <tr><td><code>org\unece\uncefact</code></td><td>UN/CEFACT units of measure (Rec. 20) and package types (Rec. 21)</td></tr>
        <tr><td><code>org\unstats</code></td><td>UN M49 country/area codes</td></tr>
        <tr><td><code>org\common</code></td><td>Cross-standard format catalogs (date, number)</td></tr>
    </tbody>
</table>

<h3>💡 At a glance</h3>
<pre class="language-php prettyprint">use org\iso\ISO4217;
use org\iso\Iso8601DateTime;
use org\ietf\Locale;

// Constants with built-in validation/lookup
ISO4217::EUR;                                  // "EUR"
ISO4217::includes('XYZ');                      // false

// ISO 8601 value-objects with property hooks
$dt = new Iso8601DateTime('2026-05-14T08:15:30+02:00');
$dt->datePart->year;                           // 2026
$dt->timePart->hours;                          // 8

// BCP 47 locales with cross-validation against ISO
new Locale('zh-Hant-TW', strict: true);        // OK
new Locale('zz-ZZ', strict: true);             // throws
</pre>

