{
    "name" : "oihana/php-standards" ,
    "type" : "library" ,
    "description" : "The Oihana PHP Standards library" ,
    "keywords" : [ "php" , "iso" , "uncefact" , "unm49" ] ,
    "homepage" : "https://github.com/BcommeBois/oihana-php-standards" ,
    "license" : "MPL-2.0" ,
    "authors" : [
        {
            "name" : "Marc Alcaraz" ,
            "email" : "marc@ooop.fr" ,
            "homepage" : "https://www.ooop.fr" ,
            "role" : "Project Founder, Lead Developer."
        }
    ],
    "support": {
        "email": "marc@ooop.fr"
    },
    "autoload" :
    {
        "psr-4" :
        {
            "org\\common\\": "src/org/common",
            "org\\ietf\\": "src/org/ietf",
            "org\\iso\\": "src/org/iso",
            "org\\unece\\uncefact\\": "src/org/unece/uncefact",
            "org\\unstats\\": "src/org/unstats"
        },
        "files":
        [
            "src/org/iso/helpers/isIso8601Date.php",
            "src/org/iso/helpers/isIso8601DateTime.php",
            "src/org/iso/helpers/isIso8601Duration.php",
            "src/org/iso/helpers/isIso8601Interval.php",
            "src/org/iso/helpers/isIso8601Recurrence.php",
            "src/org/iso/helpers/isIso8601Time.php",
            "src/org/ietf/helpers/isLocale.php",
            "src/org/iso/helpers/toIso8601Date.php",
            "src/org/iso/helpers/toIso8601DateTime.php",
            "src/org/iso/helpers/toIso8601Duration.php",
            "src/org/iso/helpers/toIso8601Time.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests"
        }
    },
    "require": {
        "php": ">=8.4",
        "oihana/php-core": "dev-main",
        "oihana/php-reflect": "dev-main"
    },
    "scripts": {
        "doc": "rm -rf docs && ./vendor/bin/phpdoc -c phpdoc.xml -v" ,
        "test": "./vendor/bin/phpunit" ,
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-text --coverage-clover build/coverage/clover.xml --coverage-html build/coverage/html" ,
        "coverage:md": [
            "@coverage" ,
            "php tools/clover-to-markdown.php build/coverage/clover.xml build/coverage/COVERAGE.md"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^12",
        "nunomaduro/collision": "^8.8",
        "phpdocumentor/shim": "^3.8"
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
